{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/aryeko/agentic-workflow-kit/config.schema.json",
  "title": "agentic-workflow-kit config",
  "type": "object",
  "properties": {
    "version": {
      "type": "number",
      "const": 1
    },
    "paths": {
      "type": "object",
      "properties": {
        "tracksDir": {
          "default": "docs/tracks",
          "type": "string",
          "minLength": 1
        },
        "specsDir": {
          "default": "docs/specs",
          "type": "string",
          "minLength": 1
        },
        "plansDir": {
          "default": "docs/plans",
          "type": "string",
          "minLength": 1
        },
        "archiveDir": {
          "default": "docs/tracks/archive",
          "type": "string",
          "minLength": 1
        },
        "prdsDir": {
          "default": "docs/prds",
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "statuses": {
      "type": "object",
      "properties": {
        "eligible": {
          "default": [
            "specced",
            "plan-approved"
          ],
          "minItems": 1,
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "inProgress": {
          "default": "implementing",
          "type": "string",
          "minLength": 1
        },
        "complete": {
          "default": [
            "done",
            "verified"
          ],
          "minItems": 1,
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": false
    },
    "tracker": {
      "type": "object",
      "properties": {
        "idPattern": {
          "default": "^[A-Z]{2,}[0-9]+$",
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "verify": {
      "type": "object",
      "properties": {
        "changed": {
          "default": null,
          "anyOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "null"
            }
          ]
        },
        "full": {
          "default": null,
          "anyOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "additionalProperties": false
    },
    "git": {
      "type": "object",
      "properties": {
        "strategy": {
          "default": "worktree",
          "type": "string",
          "enum": [
            "worktree",
            "branch"
          ]
        },
        "branchPattern": {
          "default": "{track}/{id-lc}-{slug}",
          "type": "string",
          "minLength": 1
        },
        "baseBranch": {
          "default": "main",
          "type": "string",
          "minLength": 1
        },
        "commitOnBase": {
          "default": "forbid",
          "type": "string",
          "enum": [
            "forbid",
            "allow"
          ]
        },
        "worktreeDir": {
          "default": ".worktrees",
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "pr": {
      "type": "object",
      "properties": {
        "create": {
          "default": true,
          "type": "boolean"
        },
        "ci": {
          "type": "object",
          "properties": {
            "wait": {
              "default": false,
              "type": "boolean"
            },
            "command": {
              "default": null,
              "anyOf": [
                {
                  "type": "string",
                  "minLength": 1
                },
                {
                  "type": "null"
                }
              ]
            }
          },
          "additionalProperties": false
        },
        "review": {
          "type": "object",
          "properties": {
            "wait": {
              "default": "none",
              "type": "string",
              "enum": [
                "none",
                "bot",
                "human"
              ]
            },
            "bot": {
              "default": "none",
              "type": "string",
              "minLength": 1
            },
            "triageComments": {
              "default": false,
              "type": "boolean"
            },
            "maxFixBatches": {
              "default": 1,
              "type": "integer",
              "minimum": 1,
              "maximum": 9007199254740991
            },
            "rerequestAfterFix": {
              "default": false,
              "type": "boolean"
            },
            "waitTimeoutMinutes": {
              "default": 30,
              "type": "integer",
              "minimum": 1,
              "maximum": 9007199254740991
            }
          },
          "additionalProperties": false
        },
        "merge": {
          "type": "object",
          "properties": {
            "auto": {
              "default": false,
              "type": "boolean"
            },
            "method": {
              "default": "squash",
              "type": "string",
              "enum": [
                "squash",
                "merge",
                "rebase"
              ]
            },
            "deleteBranch": {
              "default": true,
              "type": "boolean"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "implement": {
      "type": "object",
      "properties": {
        "review": {
          "type": "object",
          "properties": {
            "prePr": {
              "type": "object",
              "properties": {
                "enabled": {
                  "default": true,
                  "type": "boolean"
                },
                "mode": {
                  "default": "auto",
                  "type": "string",
                  "enum": [
                    "auto",
                    "subagent",
                    "inline"
                  ]
                },
                "maxLoops": {
                  "default": 2,
                  "type": "integer",
                  "minimum": 1,
                  "maximum": 9007199254740991
                },
                "loopMode": {
                  "default": "incremental",
                  "type": "string",
                  "enum": [
                    "incremental",
                    "full"
                  ]
                }
              },
              "additionalProperties": false
            },
            "semanticChecks": {
              "type": "object",
              "properties": {
                "enabled": {
                  "default": true,
                  "type": "boolean"
                }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        },
        "subagents": {
          "type": "object",
          "properties": {
            "enabled": {
              "default": true,
              "type": "boolean"
            },
            "maxParallel": {
              "default": 2,
              "type": "integer",
              "minimum": 1,
              "maximum": 9007199254740991
            },
            "allowWorkers": {
              "default": false,
              "type": "boolean"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "orchestrator": {
      "type": "object",
      "properties": {
        "driver": {
          "default": "codex-mcp",
          "type": "string",
          "minLength": 1
        },
        "maxParallel": {
          "default": 2,
          "type": "integer",
          "minimum": 1,
          "maximum": 9007199254740991
        },
        "stopLaunchingOnBlocked": {
          "default": true,
          "type": "boolean"
        },
        "watch": {
          "type": "object",
          "properties": {
            "enabled": {
              "default": false,
              "type": "boolean"
            },
            "wait": {
              "default": false,
              "type": "boolean"
            },
            "intervalMs": {
              "default": 300000,
              "type": "integer",
              "minimum": 1,
              "maximum": 9007199254740991
            },
            "timeoutMs": {
              "default": 300000,
              "type": "integer",
              "minimum": 1,
              "maximum": 9007199254740991
            }
          },
          "additionalProperties": false
        },
        "childTimeoutMs": {
          "default": 1800000,
          "type": "integer",
          "minimum": 1,
          "maximum": 9007199254740991
        },
        "childNoProgressTimeoutMs": {
          "default": 1800000,
          "type": "integer",
          "minimum": 1,
          "maximum": 9007199254740991
        },
        "childStartupTimeoutMs": {
          "default": 60000,
          "type": "integer",
          "minimum": 1,
          "maximum": 9007199254740991
        },
        "childMaxRuntimeMs": {
          "default": 7200000,
          "type": "integer",
          "minimum": 1,
          "maximum": 9007199254740991
        }
      },
      "additionalProperties": false
    },
    "childSession": {
      "type": "object",
      "properties": {
        "model": {
          "type": "string",
          "minLength": 1
        },
        "approvalPolicy": {
          "type": "string",
          "enum": [
            "never",
            "on-failure",
            "on-request",
            "untrusted"
          ]
        },
        "sandbox": {
          "type": "string",
          "enum": [
            "danger-full-access",
            "read-only",
            "workspace-write"
          ]
        },
        "config": {
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {}
        }
      },
      "additionalProperties": false
    },
    "codex": {
      "type": "object",
      "properties": {
        "childSession": {
          "type": "object",
          "properties": {
            "model": {
              "type": "string",
              "minLength": 1
            },
            "approvalPolicy": {
              "type": "string",
              "enum": [
                "never",
                "on-failure",
                "on-request",
                "untrusted"
              ]
            },
            "sandbox": {
              "type": "string",
              "enum": [
                "danger-full-access",
                "read-only",
                "workspace-write"
              ]
            },
            "config": {
              "type": "object",
              "propertyNames": {
                "type": "string"
              },
              "additionalProperties": {}
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "agents": {
      "type": "object",
      "properties": {
        "profiles": {
          "type": "object",
          "propertyNames": {
            "type": "string",
            "minLength": 1
          },
          "additionalProperties": {
            "type": "object",
            "properties": {
              "driver": {
                "default": "codex-mcp",
                "type": "string",
                "enum": [
                  "codex-mcp",
                  "inline"
                ]
              },
              "model": {
                "default": null,
                "anyOf": [
                  {
                    "type": "string",
                    "minLength": 1
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "reasoning": {
                "default": null,
                "anyOf": [
                  {
                    "type": "string",
                    "minLength": 1
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "approvalPolicy": {
                "default": null,
                "anyOf": [
                  {
                    "type": "string",
                    "minLength": 1
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "sandbox": {
                "default": null,
                "anyOf": [
                  {
                    "type": "string",
                    "minLength": 1
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "prompt": {
                "type": "object",
                "properties": {
                  "template": {
                    "type": "string",
                    "minLength": 1
                  },
                  "variables": {
                    "default": {},
                    "type": "object",
                    "propertyNames": {
                      "type": "string"
                    },
                    "additionalProperties": {}
                  }
                },
                "additionalProperties": false
              },
              "structuredOutput": {
                "type": "object",
                "properties": {
                  "schema": {
                    "type": "string",
                    "minLength": 1
                  },
                  "required": {
                    "default": false,
                    "type": "boolean"
                  }
                },
                "additionalProperties": false
              },
              "budget": {
                "type": "object",
                "properties": {
                  "wallMs": {
                    "type": "object",
                    "properties": {
                      "limit": {
                        "default": null,
                        "anyOf": [
                          {
                            "type": "number",
                            "minimum": 0
                          },
                          {
                            "type": "null"
                          }
                        ]
                      },
                      "warnAtPercent": {
                        "default": 80,
                        "anyOf": [
                          {
                            "type": "integer",
                            "minimum": 1,
                            "maximum": 100
                          },
                          {
                            "type": "null"
                          }
                        ]
                      },
                      "action": {
                        "default": "checkpoint-stop",
                        "type": "string",
                        "enum": [
                          "warn",
                          "stop-new-launches",
                          "checkpoint-stop",
                          "abort"
                        ]
                      }
                    },
                    "additionalProperties": false
                  },
                  "tokens": {
                    "type": "object",
                    "properties": {
                      "limit": {
                        "default": null,
                        "anyOf": [
                          {
                            "type": "number",
                            "minimum": 0
                          },
                          {
                            "type": "null"
                          }
                        ]
                      },
                      "warnAtPercent": {
                        "default": 80,
                        "anyOf": [
                          {
                            "type": "integer",
                            "minimum": 1,
                            "maximum": 100
                          },
                          {
                            "type": "null"
                          }
                        ]
                      },
                      "action": {
                        "default": "stop-new-launches",
                        "type": "string",
                        "enum": [
                          "warn",
                          "stop-new-launches",
                          "checkpoint-stop",
                          "abort"
                        ]
                      }
                    },
                    "additionalProperties": false
                  },
                  "toolCalls": {
                    "type": "object",
                    "properties": {
                      "limit": {
                        "default": null,
                        "anyOf": [
                          {
                            "type": "number",
                            "minimum": 0
                          },
                          {
                            "type": "null"
                          }
                        ]
                      },
                      "warnAtPercent": {
                        "default": 80,
                        "anyOf": [
                          {
                            "type": "integer",
                            "minimum": 1,
                            "maximum": 100
                          },
                          {
                            "type": "null"
                          }
                        ]
                      },
                      "action": {
                        "default": "checkpoint-stop",
                        "type": "string",
                        "enum": [
                          "warn",
                          "stop-new-launches",
                          "checkpoint-stop",
                          "abort"
                        ]
                      }
                    },
                    "additionalProperties": false
                  },
                  "failedToolCalls": {
                    "type": "object",
                    "properties": {
                      "limit": {
                        "default": null,
                        "anyOf": [
                          {
                            "type": "number",
                            "minimum": 0
                          },
                          {
                            "type": "null"
                          }
                        ]
                      },
                      "warnAtPercent": {
                        "default": 80,
                        "anyOf": [
                          {
                            "type": "integer",
                            "minimum": 1,
                            "maximum": 100
                          },
                          {
                            "type": "null"
                          }
                        ]
                      },
                      "action": {
                        "default": "warn",
                        "type": "string",
                        "enum": [
                          "warn",
                          "stop-new-launches",
                          "checkpoint-stop",
                          "abort"
                        ]
                      }
                    },
                    "additionalProperties": false
                  },
                  "costUsd": {
                    "type": "object",
                    "properties": {
                      "limit": {
                        "default": null,
                        "anyOf": [
                          {
                            "type": "number",
                            "minimum": 0
                          },
                          {
                            "type": "null"
                          }
                        ]
                      },
                      "warnAtPercent": {
                        "default": 80,
                        "anyOf": [
                          {
                            "type": "integer",
                            "minimum": 1,
                            "maximum": 100
                          },
                          {
                            "type": "null"
                          }
                        ]
                      },
                      "action": {
                        "default": "stop-new-launches",
                        "type": "string",
                        "enum": [
                          "warn",
                          "stop-new-launches",
                          "checkpoint-stop",
                          "abort"
                        ]
                      }
                    },
                    "additionalProperties": false
                  }
                },
                "additionalProperties": false
              },
              "host": {
                "default": {},
                "type": "object",
                "propertyNames": {
                  "type": "string"
                },
                "additionalProperties": {}
              }
            },
            "additionalProperties": false
          }
        },
        "bindings": {
          "type": "object",
          "properties": {
            "implementStory": {
              "default": "storyImplementer",
              "type": "string",
              "minLength": 1
            },
            "prePrReview": {
              "default": "prePrReviewer",
              "type": "string",
              "minLength": 1
            },
            "planTrack": {
              "default": "planner",
              "type": "string",
              "minLength": 1
            },
            "analyzeRun": {
              "default": "analyzer",
              "type": "string",
              "minLength": 1
            },
            "recoverRun": {
              "default": "recovery",
              "type": "string",
              "minLength": 1
            },
            "migrateTracker": {
              "default": "planner",
              "type": "string",
              "minLength": 1
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "required": [
    "version"
  ],
  "additionalProperties": false,
  "$comment": "Runtime validation: every agents.bindings value must reference a key in agents.profiles."
}
