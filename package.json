{
  "name": "agentic-workflow-kit",
  "version": "1.0.0",
  "description": "Deterministic control plane for delegated agent work (kit-vnext v1.0.0 rebuild).",
  "keywords": [
    "agentic-workflow-kit",
    "control-plane",
    "agents",
    "orchestration",
    "claude-code",
    "codex"
  ],
  "author": "Arye Kogan",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aryeko/agentic-workflow-kit.git"
  },
  "homepage": "https://github.com/aryeko/agentic-workflow-kit#readme",
  "bugs": {
    "url": "https://github.com/aryeko/agentic-workflow-kit/issues"
  },
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.1",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint .",
    "deps": "depcruise --config .dependency-cruiser.cjs packages tooling tests",
    "typecheck": "tsc -b",
    "test:unit": "vitest run --project unit --passWithNoTests",
    "test:int": "vitest run --project integration --passWithNoTests",
    "test:conf": "vitest run --project conformance-mock --passWithNoTests",
    "test:smoke": "vitest run --project smoke-real --passWithNoTests",
    "coverage:foundation": "vitest run --config vitest.foundation-coverage.config.ts --coverage",
    "check": "pnpm format:check && pnpm lint && pnpm deps && pnpm typecheck && pnpm test:unit && pnpm test:int && pnpm test:conf && pnpm coverage:foundation",
    "pack:dry-run": "pnpm -r pack --dry-run"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@types/node": "^25.9.3",
    "@vitest/coverage-v8": "^4.1.9",
    "dependency-cruiser": "^17.4.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
